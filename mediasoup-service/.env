PORT=${PORT:-8003}
NODE_ENV=${NODE_ENV:-development}

# MediaSoup
MEDIASOUP_WORKER_PROCESSES=${MEDIASOUP_WORKER_PROCESSES:-4}
MEDIASOUP_WORKER_RTC_PORT_RANGE_START=${MEDIASOUP_WORKER_RTC_PORT_RANGE_START:-20000}
MEDIASOUP_WORKER_RTC_PORT_RANGE_END=${MEDIASOUP_WORKER_RTC_PORT_RANGE_END:-30000}

# WebRTC
WEBRTC_ANNOUNCE_IP=${WEBRTC_ANNOUNCE_IP:-auto}
WEBRTC_LISTEN_IPS=${WEBRTC_LISTEN_IPS:-0.0.0.0}

# Redis
REDIS_HOST=${REDIS_HOST:-localhost}
REDIS_PORT=${REDIS_PORT:-6379}
REDIS_DB=${REDIS_DB:-1}

# Auth
AUTH_SERVICE_URL=${AUTH_SERVICE_URL:-http://localhost:8001}
AUTH_VERIFY_ENDPOINT=${AUTH_VERIFY_ENDPOINT:-/auth/v1/verify-token}

# Room Service
ROOM_SERVICE_URL=${ROOM_SERVICE_URL:-http://localhost:8002}

# Logging
LOG_LEVEL=${LOG_LEVEL:-debug}
LOG_FILE=${LOG_FILE:-logs/mediasoup.log}

# Audio
MAX_AUDIO_SPEAKERS=${MAX_AUDIO_SPEAKERS:-10}
AUDIO_CODECS=${AUDIO_CODECS:-opus}

# Video
VIDEO_CODECS=${VIDEO_CODECS:-vp8,vp9,h264}
DEFAULT_VIDEO_BITRATE=${DEFAULT_VIDEO_BITRATE:-500000}

# TURN
TURN_SERVER=${TURN_SERVER:-turn.example.com}
TURN_USERNAME=${TURN_USERNAME:-username}
TURN_PASSWORD=${TURN_PASSWORD:-password}
TURN_PROTO=${TURN_PROTO:-tcp}

# CORS
CORS_ORIGIN=${CORS_ORIGIN:-http://localhost:3000,http://localhost:8080}
